Menu="Docker:85"
Name="UnraidTemplateManager"
Type="xmenu"
Title="Template Manager"
Tag="docker"
---
<div id="utm-root" style="padding:12px 0">Loading Unraid Template Manager...</div>
<script>
(function() {
  var target = document.getElementById('utm-root');
  if (!target) return;
  fetch('/plugins/unraid.template.manager/UnraidTemplateManager.php', { credentials: 'same-origin' })
    .then(function(response) { return response.text(); })
    .then(function(html) { target.outerHTML = html; })
    .catch(function(error) {
      target.innerHTML = '<div style="padding:16px;border:1px solid #b44;border-radius:8px;background:#3a1f1f;color:#f4dcdc">Failed to load plugin content: ' +
        (error && error.message ? error.message : 'unknown error') + '</div>';
    });
})();
</script>
